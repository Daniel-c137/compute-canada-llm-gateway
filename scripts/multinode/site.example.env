# Site / cluster settings — copy to site.env and edit. Sourced by serve-vllm-multinode.sbatch
# (and useful to source in your own shell for build-env.sh / materialize-model.sh).
#
# Values below are the proven Rorqual set. Other Alliance clusters (Narval, Nibi, Fir, ...)
# are UNTESTED: module names, partitions, and GPUs-per-node all differ — verify with
# `module spider` and `sinfo -o "%P %G"` before first use.

# Modules loaded on login (env build) AND inside the job. THE CUDA PIN IS LOAD-BEARING:
# wheelhouse vLLM >= 0.22 requires cuda/13 (cudacompat userspace); 0.20-era wheels want
# cuda/12.x. Never bare `module load cuda` (defaults to 12.6). See
# docs/ALLIANCE_CLUSTER_GUIDE.md section 1.1 and scripts/diagnostics/ptx_jit_repro.py.
MODULES="StdEnv/2023 gcc/12.3 cuda/13.2 python/3.11.5 opencv/4.13.0"

# The vLLM venv built by build-env.sh (login node, wheelhouse).
VENV="/scratch/$USER/llm-serve/env-vllm"

# Working dir for run artifacts (SERVE_READY handoff file, canary samples) and logs.
WORKDIR="/scratch/$USER/llm-serve"
LOG_DIR="/scratch/$USER/llm-serve/logs"

# Shared HF cache (weights staged here on the login node; compute nodes have no internet).
export HF_HOME="${HF_HOME:-/scratch/$USER/llm-serve/hf}"

# Ports (head node). DP_RPC_PORT is vLLM's data-parallel rendezvous.
API_PORT=8000
DP_RPC_PORT=13345

# Optional Node.js module for JS-based smoke clients (leave empty to skip).
NODEJS_MODULE="nodejs/24.15.0"
