# Model profile: moonshotai/Kimi-K2.6 — THE PROVEN REFERENCE CONFIG
# (Rorqual job 15835049: coherence + native tool-call + turn-2 roundtrip all green on
# vLLM 0.24 wheelhouse + cuda/13.2, 3 nodes x 4xH100, TP4 x DP3 + expert-parallel.)
#
# Sourced by serve-vllm-multinode.sbatch. Everything model-specific lives HERE; the sbatch
# script is model-agnostic. Copy this file to create a profile for another model — and treat
# every value below as UNTESTED for that model until a serve proves it.

# --- identity / weights ---
# HF_REPO is the weight SOURCE; stage-model.sh downloads it and produces MODEL_PATH
# (materialized for trust_remote_code models — the HF symlink cache breaks their relative
# imports; plain snapshot symlink otherwise).
HF_REPO="moonshotai/Kimi-K2.6"
MODEL_PATH="${MODEL_PATH:-/scratch/$USER/llm-serve/kimi-model}"
SERVED_MODEL_NAME="moonshotai/Kimi-K2.6"
TRUST_REMOTE_CODE=1
NEEDS_MATERIALIZED_DIR=1

# --- tool calling / reasoning (per-model; probe `vllm serve --help` in-job, some versions
# lack --reasoning-parser entirely) ---
TOOL_CALL_PARSER="kimi_k2"
REASONING_PARSER="kimi_k2"
ENABLE_AUTO_TOOL_CHOICE=1

# Kimi thinks by default: without chat_template_kwargs:{"thinking": false} on EVERY request,
# `content` comes back empty (all text routes to reasoning_content). The kwarg KEY is
# per-model (Qwen3-class models use "enable_thinking") — hence a JSON blob, not a boolean.
# The canary battery and any client must send this on every request.
CHAT_TEMPLATE_KWARGS='{"thinking": false}'

# --- context & tuning (proven at 32K; KV lesson: 0.85 gpu-mem starved the KV pool at this
# context length — job 15080024; take headroom from max-num-seqs first) ---
MAX_MODEL_LEN=32768
GPU_MEMORY_UTILIZATION=0.90
MAX_NUM_SEQS=64
MAX_NUM_BATCHED_TOKENS=8192

# --- engine behavior ---
# enforce-eager: never serve-tested without it on this stack (the no-eager inductor path
# crashed on the mismatched-cuda-module wheels, job 15100198; possibly fine under cuda/13 —
# retest as a ONE-delta change only).
ENFORCE_EAGER=1
ENABLE_EXPERT_PARALLEL=1        # MoE
DISABLE_CUSTOM_ALL_REDUCE=1     # kept from the proven config (harmless; fixes nothing alone)
EXTRA_VLLM_ARGS="--mm-encoder-tp-mode data"

# --- canary expectations ---
# stream:false always for kimi_k2 tool calls (streaming parser broken upstream, vllm#41182);
# tool-call IDs must round-trip verbatim as functions.{name}:{idx} in multi-turn history.
CANARY_TOOLS=1
