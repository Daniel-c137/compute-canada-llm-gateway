# Model profile: Qwen/Qwen3-32B — ⚠️ EXAMPLE, NEVER SERVE-TESTED ⚠️
#
# Purpose: show what a DENSE (non-MoE), single-node-sized, non-trust-remote-code profile
# looks like next to the proven Kimi one — i.e. which knobs flip for the agentic/non-agentic
# and MoE/dense axes. Every value below is a starting point, not a validated config; the
# first serve on it is a validation event (see runbook "Honest status").
#
# Sizing (estimate-gpus.py on the real checkpoint before trusting this): ~65 GB BF16 ->
# min 2 GPUs -> single node, TP2 (or TP4 for KV headroom at long context). Single node means
# the DP machinery is idle: submit with --nodes=1 and the sbatch's TP=GPUs-per-node still holds.

# --- identity / weights ---
HF_REPO="Qwen/Qwen3-32B"
MODEL_PATH="${MODEL_PATH:-/scratch/$USER/llm-serve/qwen3-32b}"
SERVED_MODEL_NAME="Qwen/Qwen3-32B"
TRUST_REMOTE_CODE=0
NEEDS_MATERIALIZED_DIR=0        # no custom modeling code -> plain snapshot symlink

# --- tool calling / reasoning ---
# Qwen3 tool calls parse with the hermes parser (upstream repo's single-node presets use the
# same). Set TOOL_CALL_PARSER="" and CANARY_TOOLS=0 for a fully NON-agentic serve: the sbatch
# then passes no parser flags and the canary battery skips the tool phases (--no-tools).
TOOL_CALL_PARSER="hermes"
REASONING_PARSER=""             # probe `vllm serve --help` in-job before assuming one exists
ENABLE_AUTO_TOOL_CHOICE=1

# Qwen3 also thinks by default, but the kwarg KEY differs from Kimi's:
CHAT_TEMPLATE_KWARGS='{"enable_thinking": false}'

# --- context & tuning (UNVALIDATED for this model) ---
MAX_MODEL_LEN=32768
GPU_MEMORY_UTILIZATION=0.90
MAX_NUM_SEQS=64
MAX_NUM_BATCHED_TOKENS=8192

# --- engine behavior ---
# enforce-eager was a workaround for the mismatched-cuda-module wheels; under a correct
# module pairing a dense model likely doesn't need it. Left off — flip on if startup crashes
# in compiled paths.
ENFORCE_EAGER=0
ENABLE_EXPERT_PARALLEL=0        # dense
DISABLE_CUSTOM_ALL_REDUCE=0
EXTRA_VLLM_ARGS=""

# --- canary expectations ---
CANARY_TOOLS=1
